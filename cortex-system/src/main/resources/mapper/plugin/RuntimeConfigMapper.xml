<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cortex.plugin.mapper.RuntimeConfigMapper">
    
    <resultMap type="RuntimeConfig" id="RuntimeConfigResult">
        <result property="id"    column="id"    />
        <result property="runtimeType"    column="runtime_type"    />
        <result property="executablePath"    column="executable_path"    />
        <result property="customPathEnabled"    column="custom_path_enabled"    />
        <result property="version"    column="version"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectRuntimeConfigVo">
        SELECT id, runtime_type, executable_path, custom_path_enabled, version, status, create_time, update_time, remark
        FROM runtime_config
    </sql>

    <select id="selectRuntimeConfigList" parameterType="RuntimeConfig" resultMap="RuntimeConfigResult">
        <include refid="selectRuntimeConfigVo"/>
        <where>  
            <if test="runtimeType != null  and runtimeType != ''"> AND runtime_type = #{runtimeType}</if>
            <if test="customPathEnabled != null"> AND custom_path_enabled = #{customPathEnabled}</if>
            <if test="status != null  and status != ''"> AND status = #{status}</if>
        </where>
    </select>
    
    <select id="selectRuntimeConfigById" parameterType="Long" resultMap="RuntimeConfigResult">
        <include refid="selectRuntimeConfigVo"/>
        WHERE id = #{id}
    </select>

    <select id="selectRuntimeConfigByType" parameterType="String" resultMap="RuntimeConfigResult">
        <include refid="selectRuntimeConfigVo"/>
        WHERE runtime_type = #{runtimeType}
    </select>
        
    <insert id="insertRuntimeConfig" parameterType="RuntimeConfig">
        INSERT INTO runtime_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="runtimeType != null and runtimeType != ''">runtime_type,</if>
            <if test="executablePath != null">executable_path,</if>
            <if test="customPathEnabled != null">custom_path_enabled,</if>
            <if test="version != null">version,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="runtimeType != null and runtimeType != ''">#{runtimeType},</if>
            <if test="executablePath != null">#{executablePath},</if>
            <if test="customPathEnabled != null">#{customPathEnabled},</if>
            <if test="version != null">#{version},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateRuntimeConfig" parameterType="RuntimeConfig">
        UPDATE runtime_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="runtimeType != null and runtimeType != ''">runtime_type = #{runtimeType},</if>
            <if test="executablePath != null">executable_path = #{executablePath},</if>
            <if test="customPathEnabled != null">custom_path_enabled = #{customPathEnabled},</if>
            <if test="version != null">version = #{version},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        WHERE id = #{id}
    </update>

    <delete id="deleteRuntimeConfigById" parameterType="Long">
        DELETE FROM runtime_config WHERE id = #{id}
    </delete>

</mapper>
