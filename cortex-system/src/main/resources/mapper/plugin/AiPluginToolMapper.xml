<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cortex.plugin.mapper.AiPluginToolMapper">
    
    <resultMap type="AiPluginTool" id="AiPluginToolResult">
        <result property="toolId"          column="tool_id"           />
        <result property="pluginId"        column="plugin_id"         />
        <result property="toolName"        column="tool_name"         />
        <result property="toolCode"        column="tool_code"         />
        <result property="description"     column="description"       />
        <result property="inputSchema"     column="input_schema"      />
        <result property="outputSchema"    column="output_schema"     />
        <result property="exampleInput"    column="example_input"     />
        <result property="exampleOutput"   column="example_output"    />
        <result property="status"          column="status"            />
        <result property="sortOrder"       column="sort_order"        />
        <result property="createTime"      column="create_time"       />
        <result property="updateTime"      column="update_time"       />
        <result property="pluginName"      column="plugin_name"       />
        <result property="pluginType"      column="plugin_type"       />
    </resultMap>

    <sql id="selectAiPluginToolVo">
        select t.tool_id, t.plugin_id, t.tool_name, t.tool_code, t.description, 
               t.input_schema, t.output_schema, t.example_input, t.example_output,
               t.status, t.sort_order, t.create_time, t.update_time,
               p.plugin_name, p.plugin_type
        from ai_plugin_tool t
        left join ai_plugin p on t.plugin_id = p.plugin_id
    </sql>

    <select id="selectAiPluginToolList" parameterType="AiPluginTool" resultMap="AiPluginToolResult">
        <include refid="selectAiPluginToolVo"/>
        <where>  
            <if test="pluginId != null "> and t.plugin_id = #{pluginId}</if>
            <if test="toolName != null  and toolName != ''"> and t.tool_name like concat('%', #{toolName}, '%')</if>
            <if test="toolCode != null  and toolCode != ''"> and t.tool_code like concat('%', #{toolCode}, '%')</if>
            <if test="status != null  and status != ''"> and t.status = #{status}</if>
            <if test="pluginType != null  and pluginType != ''"> and p.plugin_type = #{pluginType}</if>
        </where>
        order by t.sort_order, t.tool_id
    </select>
    
    <select id="selectAiPluginToolByToolId" parameterType="Long" resultMap="AiPluginToolResult">
        <include refid="selectAiPluginToolVo"/>
        where t.tool_id = #{toolId}
    </select>

    <select id="selectAiPluginToolListByPluginId" parameterType="Long" resultMap="AiPluginToolResult">
        <include refid="selectAiPluginToolVo"/>
        where t.plugin_id = #{pluginId}
        order by t.sort_order, t.tool_id
    </select>

    <select id="selectAiPluginToolListByPluginName" parameterType="String" resultMap="AiPluginToolResult">
        <include refid="selectAiPluginToolVo"/>
        where p.plugin_name = #{pluginName}
        order by t.sort_order, t.tool_id
    </select>

    <insert id="insertAiPluginTool" parameterType="AiPluginTool" useGeneratedKeys="true" keyProperty="toolId">
        insert into ai_plugin_tool
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="pluginId != null">plugin_id,</if>
            <if test="toolName != null and toolName != ''">tool_name,</if>
            <if test="toolCode != null and toolCode != ''">tool_code,</if>
            <if test="description != null">description,</if>
            <if test="inputSchema != null">input_schema,</if>
            <if test="outputSchema != null">output_schema,</if>
            <if test="exampleInput != null">example_input,</if>
            <if test="exampleOutput != null">example_output,</if>
            <if test="status != null">status,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="pluginId != null">#{pluginId},</if>
            <if test="toolName != null and toolName != ''">#{toolName},</if>
            <if test="toolCode != null and toolCode != ''">#{toolCode},</if>
            <if test="description != null">#{description},</if>
            <if test="inputSchema != null">#{inputSchema},</if>
            <if test="outputSchema != null">#{outputSchema},</if>
            <if test="exampleInput != null">#{exampleInput},</if>
            <if test="exampleOutput != null">#{exampleOutput},</if>
            <if test="status != null">#{status},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateAiPluginTool" parameterType="AiPluginTool">
        update ai_plugin_tool
        <trim prefix="SET" suffixOverrides=",">
            <if test="pluginId != null">plugin_id = #{pluginId},</if>
            <if test="toolName != null and toolName != ''">tool_name = #{toolName},</if>
            <if test="toolCode != null and toolCode != ''">tool_code = #{toolCode},</if>
            <if test="description != null">description = #{description},</if>
            <if test="inputSchema != null">input_schema = #{inputSchema},</if>
            <if test="outputSchema != null">output_schema = #{outputSchema},</if>
            <if test="exampleInput != null">example_input = #{exampleInput},</if>
            <if test="exampleOutput != null">example_output = #{exampleOutput},</if>
            <if test="status != null">status = #{status},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where tool_id = #{toolId}
    </update>

    <delete id="deleteAiPluginToolByToolId" parameterType="Long">
        delete from ai_plugin_tool where tool_id = #{toolId}
    </delete>

    <delete id="deleteAiPluginToolByToolIds" parameterType="String">
        delete from ai_plugin_tool where tool_id in 
        <foreach item="toolId" collection="array" open="(" separator="," close=")">
            #{toolId}
        </foreach>
    </delete>

    <delete id="deleteAiPluginToolByPluginId" parameterType="Long">
        delete from ai_plugin_tool where plugin_id = #{pluginId}
    </delete>
</mapper>
