<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cortex.knowledge.mapper.AiKnowledgeBaseMapper">

    <resultMap type="AiKnowledgeBase" id="AiKnowledgeBaseResult">
        <result property="id"                 column="id"                  />
        <result property="kbName"             column="kb_name"             />
        <result property="kbCode"             column="kb_code"             />
        <result property="description"        column="description"         />
        <result property="embeddingModelId"   column="embedding_model_id"  />
        <result property="embeddingModelName" column="embedding_model_name"/>
        <result property="rerankModelId"   column="rerank_model_id"  />
        <result property="rerankModelName" column="rerank_model_name"/>
        <result property="rerankTopN"      column="rerank_top_n"     />
        <result property="chunkSize"          column="chunk_size"          />
        <result property="chunkOverlap"       column="chunk_overlap"       />
        <result property="topK"               column="top_k"               />
        <result property="chunkSeparator"    column="chunk_separator"    />
        <result property="scoreThreshold"     column="score_threshold"     />
        <result property="extractImages"   column="extract_images"   />
        <result property="imageDescEnabled" column="image_desc_enabled" />
        <result property="collectionName"     column="collection_name"     />
        <result property="documentCount"      column="document_count"      />
        <result property="chunkCount"         column="chunk_count"         />
        <result property="status"             column="status"              />
        <result property="createBy"           column="create_by"           />
        <result property="createTime"         column="create_time"         />
        <result property="updateBy"           column="update_by"           />
        <result property="updateTime"         column="update_time"         />
        <result property="remark"             column="remark"              />
    </resultMap>

    <sql id="selectAiKnowledgeBaseVo">
        select b.*, m.model_name as embedding_model_name, rm.model_name as rerank_model_name
        from ai_knowledge_base b
        left join ai_model m on b.embedding_model_id = m.model_id
        left join ai_model rm on b.rerank_model_id = rm.model_id
    </sql>

    <select id="selectAiKnowledgeBaseList" parameterType="AiKnowledgeBase" resultMap="AiKnowledgeBaseResult">
        <include refid="selectAiKnowledgeBaseVo"/>
        <where>
            <if test="kbName != null and kbName != ''"> and b.kb_name like concat('%', #{kbName}, '%')</if>
            <if test="kbCode != null and kbCode != ''"> and b.kb_code like concat('%', #{kbCode}, '%')</if>
            <if test="status != null and status != ''"> and b.status = #{status}</if>
        </where>
        order by b.create_time desc
    </select>

    <select id="selectAiKnowledgeBaseById" parameterType="Long" resultMap="AiKnowledgeBaseResult">
        <include refid="selectAiKnowledgeBaseVo"/>
        where b.id = #{id}
    </select>

    <select id="selectByKbCode" parameterType="String" resultMap="AiKnowledgeBaseResult">
        <include refid="selectAiKnowledgeBaseVo"/>
        where b.kb_code = #{kbCode}
    </select>

    <insert id="insertAiKnowledgeBase" parameterType="AiKnowledgeBase" useGeneratedKeys="true" keyProperty="id">
        insert into ai_knowledge_base
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="kbName != null">kb_name,</if>
            <if test="kbCode != null">kb_code,</if>
            <if test="description != null">description,</if>
            <if test="embeddingModelId != null">embedding_model_id,</if>
            <if test="rerankModelId != null">rerank_model_id,</if>
            <if test="rerankTopN != null">rerank_top_n,</if>
            <if test="chunkSize != null">chunk_size,</if>
            <if test="chunkOverlap != null">chunk_overlap,</if>
            <if test="topK != null">top_k,</if>
            <if test="chunkSeparator != null">chunk_separator,</if>
            <if test="scoreThreshold != null">score_threshold,</if>
            <if test="extractImages != null">extract_images,</if>
            <if test="imageDescEnabled != null">image_desc_enabled,</if>
            <if test="collectionName != null">collection_name,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="kbName != null">#{kbName},</if>
            <if test="kbCode != null">#{kbCode},</if>
            <if test="description != null">#{description},</if>
            <if test="embeddingModelId != null">#{embeddingModelId},</if>
            <if test="rerankModelId != null">#{rerankModelId},</if>
            <if test="rerankTopN != null">#{rerankTopN},</if>
            <if test="chunkSize != null">#{chunkSize},</if>
            <if test="chunkOverlap != null">#{chunkOverlap},</if>
            <if test="topK != null">#{topK},</if>
            <if test="chunkSeparator != null">#{chunkSeparator},</if>
            <if test="scoreThreshold != null">#{scoreThreshold},</if>
            <if test="extractImages != null">#{extractImages},</if>
            <if test="imageDescEnabled != null">#{imageDescEnabled},</if>
            <if test="collectionName != null">#{collectionName},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            NOW()
        </trim>
    </insert>

    <update id="updateAiKnowledgeBase" parameterType="AiKnowledgeBase">
        update ai_knowledge_base
        <trim prefix="SET" suffixOverrides=",">
            <if test="kbName != null">kb_name = #{kbName},</if>
            <if test="kbCode != null">kb_code = #{kbCode},</if>
            <if test="description != null">description = #{description},</if>
            <if test="embeddingModelId != null">embedding_model_id = #{embeddingModelId},</if>
            <if test="rerankModelId != null">rerank_model_id = #{rerankModelId},</if>
            <if test="rerankTopN != null">rerank_top_n = #{rerankTopN},</if>
            <if test="chunkSize != null">chunk_size = #{chunkSize},</if>
            <if test="chunkOverlap != null">chunk_overlap = #{chunkOverlap},</if>
            <if test="topK != null">top_k = #{topK},</if>
            <if test="chunkSeparator != null">chunk_separator = #{chunkSeparator},</if>
            <if test="scoreThreshold != null">score_threshold = #{scoreThreshold},</if>
            <if test="extractImages != null">extract_images = #{extractImages},</if>
            <if test="imageDescEnabled != null">image_desc_enabled = #{imageDescEnabled},</if>
            <if test="collectionName != null">collection_name = #{collectionName},</if>
            <if test="documentCount != null">document_count = #{documentCount},</if>
            <if test="chunkCount != null">chunk_count = #{chunkCount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = NOW()
        </trim>
        where id = #{id}
    </update>

    <update id="updateDocumentCount" parameterType="Long">
        update ai_knowledge_base set document_count = (
            select count(*) from ai_knowledge_document where kb_id = #{id}
        ) where id = #{id}
    </update>

    <update id="updateChunkCount" parameterType="Long">
        update ai_knowledge_base set chunk_count = (
            select count(*) from ai_knowledge_chunk where kb_id = #{id}
        ) where id = #{id}
    </update>

    <delete id="deleteAiKnowledgeBaseById" parameterType="Long">
        delete from ai_knowledge_base where id = #{id}
    </delete>

    <delete id="deleteAiKnowledgeBaseByIds" parameterType="Long">
        delete from ai_knowledge_base where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>