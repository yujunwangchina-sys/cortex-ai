<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cortex.agent.mapper.AiAgentApprovalGrantMapper">

    <resultMap type="com.cortex.agent.domain.AiAgentApprovalGrant" id="AiAgentApprovalGrantResult">
        <result property="grantId"         column="grant_id"          />
        <result property="sessionId"       column="session_id"        />
        <result property="agentId"         column="agent_id"          />
        <result property="pluginId"        column="plugin_id"         />
        <result property="pluginName"      column="plugin_name"       />
        <result property="grantStatus"     column="grant_status"      />
        <result property="grantedBy"       column="granted_by"        />
        <result property="businessSystem"  column="business_system"   />
        <result property="expireTime"      column="expire_time"       />
        <result property="rejectReason"    column="reject_reason"     />
        <result property="createTime"      column="create_time"       />
        <result property="updateTime"      column="update_time"       />
    </resultMap>

    <sql id="selectAiAgentApprovalGrantVo">
        select grant_id, session_id, agent_id, plugin_id, plugin_name, grant_status,
               granted_by, business_system, expire_time, reject_reason, create_time, update_time
        from ai_agent_approval_grant
    </sql>

    <select id="selectAiAgentApprovalGrantByGrantId" parameterType="Long" resultMap="AiAgentApprovalGrantResult">
        <include refid="selectAiAgentApprovalGrantVo"/>
        where grant_id = #{grantId}
    </select>

    <select id="selectAiAgentApprovalGrantList" parameterType="com.cortex.agent.domain.AiAgentApprovalGrant" resultMap="AiAgentApprovalGrantResult">
        <include refid="selectAiAgentApprovalGrantVo"/>
        <where>
            <if test="sessionId != null and sessionId != ''"> and session_id = #{sessionId}</if>
            <if test="agentId != null"> and agent_id = #{agentId}</if>
            <if test="pluginId != null"> and plugin_id = #{pluginId}</if>
            <if test="pluginName != null and pluginName != ''"> and plugin_name = #{pluginName}</if>
            <if test="grantStatus != null and grantStatus != ''"> and grant_status = #{grantStatus}</if>
            <if test="businessSystem != null and businessSystem != ''"> and business_system = #{businessSystem}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectPendingBySessionId" parameterType="String" resultMap="AiAgentApprovalGrantResult">
        <include refid="selectAiAgentApprovalGrantVo"/>
        where session_id = #{sessionId} and grant_status = '2'
        order by create_time desc
    </select>

    <select id="selectBySessionAndPlugin" resultMap="AiAgentApprovalGrantResult">
        <include refid="selectAiAgentApprovalGrantVo"/>
        where session_id = #{sessionId} and plugin_id = #{pluginId}
        order by create_time desc limit 1
    </select>

    <insert id="insertAiAgentApprovalGrant" parameterType="com.cortex.agent.domain.AiAgentApprovalGrant" useGeneratedKeys="true" keyProperty="grantId">
        insert into ai_agent_approval_grant
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="sessionId != null and sessionId != ''">session_id,</if>
            <if test="agentId != null">agent_id,</if>
            <if test="pluginId != null">plugin_id,</if>
            <if test="pluginName != null and pluginName != ''">plugin_name,</if>
            <if test="grantStatus != null">grant_status,</if>
            <if test="grantedBy != null and grantedBy != ''">granted_by,</if>
            <if test="businessSystem != null and businessSystem != ''">business_system,</if>
            <if test="expireTime != null">expire_time,</if>
            <if test="rejectReason != null">reject_reason,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="sessionId != null and sessionId != ''">#{sessionId},</if>
            <if test="agentId != null">#{agentId},</if>
            <if test="pluginId != null">#{pluginId},</if>
            <if test="pluginName != null and pluginName != ''">#{pluginName},</if>
            <if test="grantStatus != null">#{grantStatus},</if>
            <if test="grantedBy != null and grantedBy != ''">#{grantedBy},</if>
            <if test="businessSystem != null and businessSystem != ''">#{businessSystem},</if>
            <if test="expireTime != null">#{expireTime},</if>
            <if test="rejectReason != null">#{rejectReason},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAiAgentApprovalGrant" parameterType="com.cortex.agent.domain.AiAgentApprovalGrant">
        update ai_agent_approval_grant
        <trim prefix="SET" suffixOverrides=",">
            <if test="grantStatus != null">grant_status = #{grantStatus},</if>
            <if test="grantedBy != null and grantedBy != ''">granted_by = #{grantedBy},</if>
            <if test="expireTime != null">expire_time = #{expireTime},</if>
            <if test="rejectReason != null">reject_reason = #{rejectReason},</if>
            update_time = sysdate()
        </trim>
        where grant_id = #{grantId}
    </update>

    <delete id="deleteAiAgentApprovalGrantByGrantId" parameterType="Long">
        delete from ai_agent_approval_grant where grant_id = #{grantId}
    </delete>

    <delete id="deleteBySessionId" parameterType="String">
        delete from ai_agent_approval_grant where session_id = #{sessionId}
    </delete>

    <delete id="cleanupExpired">
        delete from ai_agent_approval_grant
        where grant_status = '2' and expire_time is not null and expire_time &lt; NOW()
    </delete>
</mapper>
