<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cortex.agent.mapper.AiAgentMapper">
    
    <resultMap type="com.cortex.agent.domain.AiAgent" id="AiAgentResult">
        <result property="id"    column="id"    />
        <result property="agentName"    column="agent_name"    />
        <result property="agentCode"    column="agent_code"    />
        <result property="systemPrompt"    column="system_prompt"    />
        <result property="description"    column="description"    />
        <result property="status"    column="status"    />
        <result property="sortOrder"    column="sort_order"    />
        <result property="maxIterations"    column="max_iterations"    />
        <result property="modelPreference"    column="model_preference"    />
        <result property="temperature"    column="temperature"    />
        <result property="businessSystem"    column="business_system"    />
        <result property="apiKey"    column="api_key"    />
        <result property="avatar"    column="avatar"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectAiAgentVo">
        select id, agent_name, agent_code, system_prompt, description, status, sort_order, 
               max_iterations, model_preference, temperature, business_system, api_key, avatar,
               create_by, create_time, update_by, update_time, remark 
        from ai_agent
    </sql>

    <select id="selectAiAgentList" parameterType="com.cortex.agent.domain.AiAgent" resultMap="AiAgentResult">
        <include refid="selectAiAgentVo"/>
        <where>  
            <if test="agentName != null and agentName != ''"> 
                and agent_name like concat('%', #{agentName}, '%')
            </if>
            <if test="agentCode != null and agentCode != ''"> 
                and agent_code = #{agentCode}
            </if>
            <if test="status != null and status != ''"> 
                and status = #{status}
            </if>
        </where>
        order by sort_order asc, create_time desc
    </select>
    
    <select id="selectAiAgentById" parameterType="Long" resultMap="AiAgentResult">
        <include refid="selectAiAgentVo"/>
        where id = #{id}
    </select>

    <select id="selectAiAgentByCode" parameterType="String" resultMap="AiAgentResult">
        <include refid="selectAiAgentVo"/>
        where agent_code = #{agentCode}
    </select>

    <select id="checkAgentCodeUnique" parameterType="String" resultMap="AiAgentResult">
        <include refid="selectAiAgentVo"/>
        where agent_code = #{agentCode} limit 1
    </select>
        
    <insert id="insertAiAgent" parameterType="com.cortex.agent.domain.AiAgent" useGeneratedKeys="true" keyProperty="id">
        insert into ai_agent
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="agentName != null and agentName != ''">agent_name,</if>
            <if test="agentCode != null and agentCode != ''">agent_code,</if>
            <if test="systemPrompt != null">system_prompt,</if>
            <if test="description != null">description,</if>
            <if test="status != null">status,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="maxIterations != null">max_iterations,</if>
            <if test="modelPreference != null">model_preference,</if>
            <if test="temperature != null">temperature,</if>
            <if test="businessSystem != null">business_system,</if>
            <if test="apiKey != null">api_key,</if>
            <if test="avatar != null">avatar,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="agentName != null and agentName != ''">#{agentName},</if>
            <if test="agentCode != null and agentCode != ''">#{agentCode},</if>
            <if test="systemPrompt != null">#{systemPrompt},</if>
            <if test="description != null">#{description},</if>
            <if test="status != null">#{status},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="maxIterations != null">#{maxIterations},</if>
            <if test="modelPreference != null">#{modelPreference},</if>
            <if test="temperature != null">#{temperature},</if>
            <if test="businessSystem != null">#{businessSystem},</if>
            <if test="apiKey != null">#{apiKey},</if>
            <if test="avatar != null">#{avatar},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
         </trim>
    </insert>

    <update id="updateAiAgent" parameterType="com.cortex.agent.domain.AiAgent">
        update ai_agent
        <trim prefix="SET" suffixOverrides=",">
            <if test="agentName != null and agentName != ''">agent_name = #{agentName},</if>
            <if test="agentCode != null and agentCode != ''">agent_code = #{agentCode},</if>
            <if test="systemPrompt != null">system_prompt = #{systemPrompt},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="maxIterations != null">max_iterations = #{maxIterations},</if>
            <if test="modelPreference != null">model_preference = #{modelPreference},</if>
            <if test="temperature != null">temperature = #{temperature},</if>
            <if test="businessSystem != null">business_system = #{businessSystem},</if>
            <if test="apiKey != null">api_key = #{apiKey},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteAiAgentById" parameterType="Long">
        delete from ai_agent where id = #{id}
    </delete>

    <delete id="deleteAiAgentByIds" parameterType="String">
        delete from ai_agent where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectAiAgentByApiKey" resultMap="AiAgentResult">
        <include refid="selectAiAgentVo"/>
        where api_key = #{apiKey}
    </select>
</mapper>
