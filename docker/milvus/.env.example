# CortexAI Docker 环境变量配置示例
# 复制此文件为 .env 并修改配置

# ===================
# MySQL 配置
# ===================
MYSQL_ROOT_PASSWORD=cortexai@2026
MYSQL_DATABASE=cortex-vue
MYSQL_PORT=3306

# ===================
# Redis 配置
# ===================
REDIS_PORT=6379
# REDIS_PASSWORD=cortexai@2026  # 取消注释以启用密码

# ===================
# MinIO 配置
# ===================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_CONSOLE_PORT=9001
MINIO_API_PORT=9000

# ===================
# Milvus 配置
# ===================
MILVUS_GRPC_PORT=19530
MILVUS_HEALTH_PORT=9091

# ===================
# etcd 配置
# ===================
ETCD_PORT=2379

# ===================
# 时区配置
# ===================
TZ=Asia/Shanghai
