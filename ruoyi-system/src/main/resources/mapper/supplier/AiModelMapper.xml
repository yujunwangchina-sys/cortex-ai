<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.supplier.mapper.AiModelMapper">
    
    <resultMap type="com.ruoyi.supplier.domain.AiModel" id="AiModelResult">
        <id     property="modelId"         column="model_id"         />
        <result property="supplierId"      column="supplier_id"      />
        <result property="modelName"       column="model_name"       />
        <result property="modelCode"       column="model_code"       />
        <result property="modelType"       column="model_type"       />
        <result property="contextLength"   column="context_length"   />
        <result property="maxTokens"       column="max_tokens"       />
        <result property="temperature"     column="temperature"      />
        <result property="topP"            column="top_p"            />
        <result property="status"          column="status"           />
        <result property="sortOrder"       column="sort_order"       />
        <result property="createBy"        column="create_by"        />
        <result property="createTime"      column="create_time"      />
        <result property="updateBy"        column="update_by"        />
        <result property="updateTime"      column="update_time"      />
        <result property="remark"          column="remark"           />
        <result property="supplierName"    column="supplier_name"    />
    </resultMap>
    
    <sql id="selectAiModelVo">
        select m.model_id, m.supplier_id, m.model_name, m.model_code, m.model_type, m.context_length, 
               m.max_tokens, m.temperature, m.top_p, m.status, m.sort_order,
               m.create_by, m.create_time, m.update_by, m.update_time, m.remark,
               s.supplier_name
        from ai_model m
        left join ai_supplier s on m.supplier_id = s.supplier_id
    </sql>
    
    <select id="selectAiModelList" parameterType="com.ruoyi.supplier.domain.AiModel" resultMap="AiModelResult">
        <include refid="selectAiModelVo"/>
        <where>
            <if test="supplierId != null">
                AND m.supplier_id = #{supplierId}
            </if>
            <if test="modelName != null and modelName != ''">
                AND m.model_name like concat('%', #{modelName}, '%')
            </if>
            <if test="modelCode != null and modelCode != ''">
                AND m.model_code like concat('%', #{modelCode}, '%')
            </if>
            <if test="modelType != null and modelType != ''">
                AND m.model_type = #{modelType}
            </if>
            <if test="status != null and status != ''">
                AND m.status = #{status}
            </if>
        </where>
        order by m.sort_order asc, m.model_id asc
    </select>
    
    <select id="selectAiModelByModelId" parameterType="Long" resultMap="AiModelResult">
        <include refid="selectAiModelVo"/>
        where m.model_id = #{modelId}
    </select>
    
    <select id="selectAiModelListBySupplierId" parameterType="Long" resultMap="AiModelResult">
        <include refid="selectAiModelVo"/>
        where m.supplier_id = #{supplierId}
        order by m.sort_order asc, m.model_id asc
    </select>
    
    <insert id="insertAiModel" parameterType="com.ruoyi.supplier.domain.AiModel" useGeneratedKeys="true" keyProperty="modelId">
        insert into ai_model (
            <if test="supplierId != null">supplier_id,</if>
            <if test="modelName != null and modelName != ''">model_name,</if>
            <if test="modelCode != null and modelCode != ''">model_code,</if>
            <if test="modelType != null and modelType != ''">model_type,</if>
            <if test="contextLength != null">context_length,</if>
            <if test="maxTokens != null">max_tokens,</if>
            <if test="temperature != null">temperature,</if>
            <if test="topP != null">top_p,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="supplierId != null">#{supplierId},</if>
            <if test="modelName != null and modelName != ''">#{modelName},</if>
            <if test="modelCode != null and modelCode != ''">#{modelCode},</if>
            <if test="modelType != null and modelType != ''">#{modelType},</if>
            <if test="contextLength != null">#{contextLength},</if>
            <if test="maxTokens != null">#{maxTokens},</if>
            <if test="temperature != null">#{temperature},</if>
            <if test="topP != null">#{topP},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>
    
    <update id="updateAiModel" parameterType="com.ruoyi.supplier.domain.AiModel">
        update ai_model 
        <set>
            <if test="supplierId != null">supplier_id = #{supplierId},</if>
            <if test="modelName != null and modelName != ''">model_name = #{modelName},</if>
            <if test="modelCode != null and modelCode != ''">model_code = #{modelCode},</if>
            <if test="modelType != null and modelType != ''">model_type = #{modelType},</if>
            <if test="contextLength != null">context_length = #{contextLength},</if>
            <if test="maxTokens != null">max_tokens = #{maxTokens},</if>
            <if test="temperature != null">temperature = #{temperature},</if>
            <if test="topP != null">top_p = #{topP},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where model_id = #{modelId}
    </update>
    
    <delete id="deleteAiModelByModelId" parameterType="Long">
        delete from ai_model where model_id = #{modelId}
    </delete>
    
    <delete id="deleteAiModelByModelIds" parameterType="Long">
        delete from ai_model where model_id in 
        <foreach item="modelId" collection="array" open="(" separator="," close=")">
            #{modelId}
        </foreach>
    </delete>
    
    <delete id="deleteAiModelBySupplierId" parameterType="Long">
        delete from ai_model where supplier_id = #{supplierId}
    </delete>
    
</mapper>
