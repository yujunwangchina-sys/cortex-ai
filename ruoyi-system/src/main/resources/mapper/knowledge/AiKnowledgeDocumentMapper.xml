<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.knowledge.mapper.AiKnowledgeDocumentMapper">

    <resultMap type="AiKnowledgeDocument" id="AiKnowledgeDocumentResult">
        <result property="id"             column="id"              />
        <result property="kbId"           column="kb_id"           />
        <result property="fileName"       column="file_name"       />
        <result property="filePath"       column="file_path"       />
        <result property="fileType"       column="file_type"       />
        <result property="fileSize"       column="file_size"       />
        <result property="contentText"    column="content_text"    />
        <result property="chunkCount"     column="chunk_count"     />
        <result property="docCategory"    column="doc_category"    />
        <result property="docTags"        column="doc_tags"        />
        <result property="docSource"      column="doc_source"      />
        <result property="docAuthor"      column="doc_author"      />
        <result property="effectiveDate"  column="effective_date"  />
        <result property="extraMetadata"  column="extra_metadata"  />
        <result property="status"         column="status"          />
        <result property="errorMessage"   column="error_message"   />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
    </resultMap>

    <sql id="selectAiKnowledgeDocumentVo">
        select id, kb_id, file_name, file_path, file_type, file_size,
               content_text, chunk_count, doc_category, doc_tags, doc_source,
               doc_author, effective_date, extra_metadata, status, error_message,
               create_by, create_time, update_by, update_time
        from ai_knowledge_document
    </sql>

    <select id="selectAiKnowledgeDocumentList" parameterType="AiKnowledgeDocument" resultMap="AiKnowledgeDocumentResult">
        <include refid="selectAiKnowledgeDocumentVo"/>
        <where>
            <if test="kbId != null"> and kb_id = #{kbId}</if>
            <if test="fileName != null and fileName != ''"> and file_name like concat('%', #{fileName}, '%')</if>
            <if test="fileType != null and fileType != ''"> and file_type = #{fileType}</if>
            <if test="docCategory != null and docCategory != ''"> and doc_category = #{docCategory}</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectAiKnowledgeDocumentById" parameterType="Long" resultMap="AiKnowledgeDocumentResult">
        <include refid="selectAiKnowledgeDocumentVo"/>
        where id = #{id}
    </select>

    <insert id="insertAiKnowledgeDocument" parameterType="AiKnowledgeDocument" useGeneratedKeys="true" keyProperty="id">
        insert into ai_knowledge_document
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="kbId != null">kb_id,</if>
            <if test="fileName != null">file_name,</if>
            <if test="filePath != null">file_path,</if>
            <if test="fileType != null">file_type,</if>
            <if test="fileSize != null">file_size,</if>
            <if test="contentText != null">content_text,</if>
            <if test="chunkCount != null">chunk_count,</if>
            <if test="docCategory != null">doc_category,</if>
            <if test="docTags != null">doc_tags,</if>
            <if test="docSource != null">doc_source,</if>
            <if test="docAuthor != null">doc_author,</if>
            <if test="effectiveDate != null">effective_date,</if>
            <if test="extraMetadata != null">extra_metadata,</if>
            <if test="status != null">status,</if>
            <if test="errorMessage != null">error_message,</if>
            <if test="createBy != null">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="kbId != null">#{kbId},</if>
            <if test="fileName != null">#{fileName},</if>
            <if test="filePath != null">#{filePath},</if>
            <if test="fileType != null">#{fileType},</if>
            <if test="fileSize != null">#{fileSize},</if>
            <if test="contentText != null">#{contentText},</if>
            <if test="chunkCount != null">#{chunkCount},</if>
            <if test="docCategory != null">#{docCategory},</if>
            <if test="docTags != null">#{docTags},</if>
            <if test="docSource != null">#{docSource},</if>
            <if test="docAuthor != null">#{docAuthor},</if>
            <if test="effectiveDate != null">#{effectiveDate},</if>
            <if test="extraMetadata != null">#{extraMetadata},</if>
            <if test="status != null">#{status},</if>
            <if test="errorMessage != null">#{errorMessage},</if>
            <if test="createBy != null">#{createBy},</if>
            NOW()
        </trim>
    </insert>

    <update id="updateAiKnowledgeDocument" parameterType="AiKnowledgeDocument">
        update ai_knowledge_document
        <trim prefix="SET" suffixOverrides=",">
            <if test="kbId != null">kb_id = #{kbId},</if>
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="filePath != null">file_path = #{filePath},</if>
            <if test="fileType != null">file_type = #{fileType},</if>
            <if test="fileSize != null">file_size = #{fileSize},</if>
            <if test="contentText != null">content_text = #{contentText},</if>
            <if test="chunkCount != null">chunk_count = #{chunkCount},</if>
            <if test="docCategory != null">doc_category = #{docCategory},</if>
            <if test="docTags != null">doc_tags = #{docTags},</if>
            <if test="docSource != null">doc_source = #{docSource},</if>
            <if test="docAuthor != null">doc_author = #{docAuthor},</if>
            <if test="effectiveDate != null">effective_date = #{effectiveDate},</if>
            <if test="extraMetadata != null">extra_metadata = #{extraMetadata},</if>
            <if test="status != null">status = #{status},</if>
            <if test="errorMessage != null">error_message = #{errorMessage},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = NOW()
        </trim>
        where id = #{id}
    </update>

    <update id="updateStatus">
        update ai_knowledge_document set status = #{status},
        <if test="errorMessage != null">error_message = #{errorMessage},</if>
        update_time = NOW()
        where id = #{id}
    </update>

    <delete id="deleteAiKnowledgeDocumentById" parameterType="Long">
        delete from ai_knowledge_document where id = #{id}
    </delete>

    <delete id="deleteAiKnowledgeDocumentByIds" parameterType="Long">
        delete from ai_knowledge_document where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteByKbId" parameterType="Long">
        delete from ai_knowledge_document where kb_id = #{kbId}
    </delete>

</mapper>